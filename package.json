{
  "name": "dev-server",
  "type": "module",
  "version": "1.0.0",
  "description": "本地开发服务器，支持文件监听和自动刷新",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node .",
    "watch": "nodemon --exec tsc",
    "dev": "nodemon --exec \"tsc && node . \"",
    "test": "node . example/index.html example --log-level=debug"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "express": "^4.22.1",
    "log4js": "^6.9.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.11",
    "typescript": "^5.9.3"
  }
}